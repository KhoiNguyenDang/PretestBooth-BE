generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?  // User's full name
  password  String
  studentCode String?  @unique
  className   String?
  role      Role     @default(STUDENT)
  refreshToken  String?
  isEmailVerified Boolean @default(false)
  emailVerificationToken String?
  emailVerificationExpiry DateTime?
  resetPasswordCode String?
  resetPasswordExpiry DateTime?
  
  // Account management
  isLocked      Boolean   @default(false)
  lockedAt      DateTime?
  lockedReason  String?
  dateOfBirth   DateTime? @db.Date  // For default password generation (DDMM)
  totalPoints   Int       @default(0)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  createdProblems   Problem[]           @relation("ProblemCreator")
  createdQuestions  Question[]          @relation("QuestionCreator")
  submissions       Submission[]
  createdExams      Exam[]              @relation("ExamCreator")
  examSessions      ExamSession[]
  bookings          Booking[]
  boothStatusLogs   BoothStatusLog[]
  pointTransactions PointTransaction[]
  practiceSessions  PracticeSession[]
  
  // Indexes for common queries
  @@index([email])
  @@index([studentCode])
  @@index([role])
  @@index([isEmailVerified])
  @@index([isLocked])
}

enum Role {
  STUDENT
  LECTURER
  ADMIN
}

// Problem difficulty levels (like LeetCode)
enum Difficulty {
  EASY
  MEDIUM
  HARD
}

// Problem model for coding challenges
model Problem {
  id          String     @id @default(uuid())
  title       String
  slug        String     @unique
  description String     @db.Text
  difficulty  Difficulty @default(MEDIUM)
  
  // Code templates for different languages
  starterCode Json?      // { "javascript": "function solve() {}", "python": "def solve():", ... }
  
  // Constraints and hints
  constraints String?    @db.Text
  hints       String[]   // Array of hints
  
  // Problem metadata
  timeLimit   Int        @default(1000)  // in milliseconds
  memoryLimit Int        @default(256)   // in MB

  // Function signature metadata for driver code generation
  functionName String   @default("solution")
  inputTypes   String[] @default([])
  outputType   String   @default("void")
  argNames     String[] @default([])
  
  // Stats
  totalSubmissions Int   @default(0)
  acceptedSubmissions Int @default(0)
  
  // Status
  isPublished Boolean    @default(false)
  
  // Classification (optional - links to question bank subjects/topics)
  subjectId   String?
  subject     Subject?   @relation(fields: [subjectId], references: [id])
  topicId     String?
  topic       Topic?     @relation(fields: [topicId], references: [id])
  
  // Classification (Category tree - parallel)
  categoryId  String?
  category    Category?  @relation(fields: [categoryId], references: [id])
  
  // Relations
  creatorId   String
  creator     User       @relation("ProblemCreator", fields: [creatorId], references: [id])
  testCases   TestCase[]
  submissions Submission[]
  examItems   ExamItem[]  @relation("ProblemExamItems")
  practiceItems PracticeSessionItem[]
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  @@index([difficulty])
  @@index([isPublished])
  @@index([creatorId])
  @@index([subjectId])
  @@index([topicId])
  @@index([categoryId])
}

// TestCase model with hidden test cases support
model TestCase {
  id          String   @id @default(uuid())
  
  // Test case data
  input       String   @db.Text
  expectedOutput String @db.Text
  
  // Explanation shown to users (only for visible test cases)
  explanation String?  @db.Text
  
  // Hidden test case flag (like LeetCode)
  isHidden    Boolean  @default(false)
  
  // Sample test case (shown in problem description)
  isSample    Boolean  @default(false)
  
  // Order of test case
  order       Int      @default(0)
  
  // Relations
  problemId   String
  problem     Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([problemId])
  @@index([isHidden])
  @@index([isSample])
}

// Submission status enum
enum SubmissionStatus {
  PENDING
  ACCEPTED
  WRONG_ANSWER
  COMPILE_ERROR
  RUNTIME_ERROR
  TIME_LIMIT_EXCEEDED
  MEMORY_LIMIT_EXCEEDED
}

// Submission model for storing user code submissions
model Submission {
  id              String           @id @default(uuid())
  
  // Code submitted
  language        String
  languageVersion String?
  sourceCode      String           @db.Text
  
  // Execution results
  status          SubmissionStatus @default(PENDING)
  totalTestCases  Int              @default(0)
  passedTestCases Int              @default(0)
  failedTestCases Int              @default(0)
  
  // Timing information
  executionTime   Int?             // Total execution time in ms
  networkTime     Int?             // Network latency in ms
  totalTime       Int?             // Total time (execution + network) in ms
  
  // Error information
  compileOutput   String?          @db.Text
  errorMessage    String?          @db.Text
  
  // Detailed results for each test case (JSON array)
  testCaseResults Json?            // Array of test case results
  
  // Relations
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId       String
  problem         Problem          @relation(fields: [problemId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime         @default(now())
  
  @@index([userId])
  @@index([problemId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, problemId])
}

// ==================== QUESTION BANK ====================

// Question type enum
enum QuestionType {
  SINGLE_CHOICE    // Single correct answer (ABCD)
  MULTIPLE_CHOICE  // Multiple correct answers
  SHORT_ANSWER     // Free-text short answer
}

// Subject model for question classification
model Subject {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?   @db.Text
  
  // Relations
  topics      Topic[]
  questions   Question[]
  problems    Problem[]
  exams       Exam[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Topic model (belongs to a Subject)
model Topic {
  id          String    @id @default(uuid())
  name        String
  
  // Relations
  subjectId   String
  subject     Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  questions   Question[]
  problems    Problem[]
  exams       Exam[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@unique([subjectId, name])
  @@index([subjectId])
}

// Question model for multiple-choice question bank
model Question {
  id            String       @id @default(uuid())
  
  // Question content
  content       String       @db.Text
  questionType  QuestionType @default(SINGLE_CHOICE)
  difficulty    Difficulty   @default(MEDIUM)
  
  // For SHORT_ANSWER questions
  correctAnswer String?      @db.Text
  
  // Explanation of the answer
  explanation   String?      @db.Text
  
  // Status
  isPublished   Boolean      @default(false)
  
  // Review & Quality tracking
  lastReviewedAt DateTime?
  reviewNotes    String?      @db.Text
  qualityScore   Int?         // 1-5 quality rating
  usageCount     Int          @default(0)
  estimatedTime  Int?         // Estimated answer time in seconds
  
  // Classification (Subject/Topic - existing)
  subjectId     String
  subject       Subject      @relation(fields: [subjectId], references: [id])
  topicId       String?
  topic         Topic?       @relation(fields: [topicId], references: [id])
  
  // Classification (Category tree - parallel)
  categoryId    String?
  category      Category?    @relation(fields: [categoryId], references: [id])
  
  // Creator
  creatorId     String
  creator       User         @relation("QuestionCreator", fields: [creatorId], references: [id])
  
  // Relations
  choices       QuestionChoice[]
  examItems     ExamItem[]   @relation("QuestionExamItems")
  practiceItems PracticeSessionItem[]
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  
  @@index([questionType])
  @@index([difficulty])
  @@index([isPublished])
  @@index([subjectId])
  @@index([topicId])
  @@index([categoryId])
  @@index([creatorId])
}

// QuestionChoice model for answer options
model QuestionChoice {
  id          String   @id @default(uuid())
  
  // Choice content
  content     String   @db.Text
  isCorrect   Boolean  @default(false)
  order       Int      @default(0)
  
  // Relations
  questionId  String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([questionId])
}

// ==================== EXAM SYSTEM ====================

// Exam section types
enum ExamSection {
  QUESTION  // Multiple-choice / short-answer from question bank
  PROBLEM   // Coding problems (LeetCode-style)
}

enum ExamVisibility {
  PRIVATE
  PUBLIC
}

// Exam session status
enum ExamSessionStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

// Exam model - the exam template created by a lecturer
model Exam {
  id          String      @id @default(uuid())
  title       String
  description String?     @db.Text
  
  // Configuration
  questionCount Int       @default(0)   // Number of MC/short-answer questions
  problemCount  Int       @default(0)   // Number of coding problems
  duration      Int       @default(60)  // Duration in minutes
  
  // Filtering options used during generation
  difficulty  Difficulty?
  includeProblemsRelatedToQuestions Boolean @default(false)
  
  // Shuffle settings
  shuffleQuestions Boolean @default(true)   // Shuffle question order per student
  shuffleChoices  Boolean @default(true)   // Shuffle answer choices per student
  
  // Classification
  subjectId   String?
  subject     Subject?   @relation(fields: [subjectId], references: [id])
  topicId     String?
  topic       Topic?     @relation(fields: [topicId], references: [id])
  
  // Status
  isPublished Boolean    @default(false)
  visibility  ExamVisibility @default(PRIVATE)
  publishAt   DateTime?
  publishedAt DateTime?
  
  // Creator
  creatorId   String
  creator     User       @relation("ExamCreator", fields: [creatorId], references: [id])
  
  // Relations
  items       ExamItem[]
  sessions    ExamSession[]
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  @@index([creatorId])
  @@index([subjectId])
  @@index([topicId])
  @@index([isPublished])
  @@index([visibility])
  @@index([publishAt])
}

// ExamItem - a concrete item (question or problem) in an exam
model ExamItem {
  id        String      @id @default(uuid())
  
  // Which exam this belongs to
  examId    String
  exam      Exam        @relation(fields: [examId], references: [id], onDelete: Cascade)
  
  // Either a question or a problem (exactly one should be set)
  questionId String?
  question   Question?   @relation("QuestionExamItems", fields: [questionId], references: [id])
  problemId  String?
  problem    Problem?    @relation("ProblemExamItems", fields: [problemId], references: [id])
  
  // Section type
  section   ExamSection
  
  // Canonical (unshuffled) order
  order     Int         @default(0)
  
  // Points for this item
  points    Float       @default(1.0)
  
  // Relations
  sessionAnswers ExamSessionAnswer[]
  
  createdAt DateTime    @default(now())
  
  @@unique([examId, questionId])
  @@unique([examId, problemId])
  @@index([examId])
  @@index([section])
}

// ExamSession - one student's attempt at an exam
model ExamSession {
  id        String            @id @default(uuid())
  
  // Which exam
  examId    String
  exam      Exam              @relation(fields: [examId], references: [id], onDelete: Cascade)
  
  // Which student
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Deterministic shuffle seed
  seed      Int
  
  // Timing
  startedAt  DateTime         @default(now())
  finishedAt DateTime?
  
  // Scoring
  score      Float?
  maxScore   Float?
  
  // Status
  status    ExamSessionStatus @default(IN_PROGRESS)
  
  // Relations
  answers           ExamSessionAnswer[]
  proctoringEvents  ProctoringEvent[]
  
  createdAt DateTime          @default(now())
  
  @@unique([examId, userId])
  @@index([examId])
  @@index([userId])
  @@index([status])
}

// ExamSessionAnswer - each answer in a session
model ExamSessionAnswer {
  id          String      @id @default(uuid())
  
  // Which session
  sessionId   String
  session     ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  // Which exam item
  examItemId  String
  examItem    ExamItem    @relation(fields: [examItemId], references: [id], onDelete: Cascade)
  
  // For MC questions - selected choice IDs
  selectedChoiceIds String[]
  
  // For short-answer questions
  textAnswer  String?     @db.Text
  
  // For coding problems - reference to submission
  submissionId String?
  
  // For coding problems - store source code for deferred execution on submit
  sourceCode      String?   @db.Text
  language        String?
  languageVersion String?
  
  // Grading
  isCorrect   Boolean?
  score       Float?
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  @@unique([sessionId, examItemId])
  @@index([sessionId])
  @@index([examItemId])
}

// ==================== HIERARCHICAL CATEGORY TREE ====================
// Runs in parallel with existing Subject/Topic classification

model Category {
  id          String     @id @default(uuid())
  name        String
  description String?    @db.Text
  level       Int        @default(0)
  
  // Self-referencing tree
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  
  // Relations
  questions   Question[]
  problems    Problem[]
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  @@unique([parentId, name])
  @@index([parentId])
  @@index([level])
}

// ==================== BOOTH MANAGEMENT ====================

enum BoothStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

model Booth {
  id          String      @id @default(uuid())
  name        String      @unique      // "Booth 01", "Booth 02", etc.
  code        String?     @unique      // Human-friendly booth code used for OTP activation
  description String?
  status      BoothStatus @default(ACTIVE)
  location    String?                  // Room/building info

  // OTP activation state (admin issues OTP, kiosk activates by booth code + OTP)
  activationOtpHash      String?
  activationOtpExpiresAt DateTime?
  activationOtpUsedAt    DateTime?
  activationOtpAttempts  Int         @default(0)

  // Current active booth session
  sessionTokenHash String?
  sessionActivatedAt DateTime?
  
  bookings    Booking[]
  statusLogs  BoothStatusLog[]
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  @@index([status])
}

model BoothStatusLog {
  id              String      @id @default(uuid())
  boothId         String
  booth           Booth       @relation(fields: [boothId], references: [id], onDelete: Cascade)
  fromStatus      BoothStatus
  toStatus        BoothStatus
  note            String      @db.Text
  changedByUserId String?
  changedByUser   User?       @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)
  changedAt       DateTime    @default(now())

  @@index([boothId, changedAt])
  @@index([changedByUserId])
}

// ==================== BOOKING / SCHEDULING ====================

enum BookingType {
  PRACTICE
  EXAM
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

model BookingDurationOption {
  id              String      @id @default(uuid())
  type            BookingType
  durationMinutes Int
  isActive        Boolean     @default(true)
  displayOrder    Int?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([type, durationMinutes])
  @@index([type, isActive])
}

model Booking {
  id           String        @id @default(uuid())
  
  // Who & Where
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  boothId      String
  booth        Booth         @relation(fields: [boothId], references: [id])
  
  // What & When
  type         BookingType
  date         DateTime      @db.Date
  startTime    DateTime      // Full datetime for the start
  endTime      DateTime      // Full datetime for the end
  
  // Status tracking
  status       BookingStatus @default(PENDING)
  checkedInAt  DateTime?
  checkedOutAt DateTime?
  
  // Optional link to practice/exam session
  examSessionId    String?
  practiceSessionId String?
  
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  
  @@index([userId])
  @@index([boothId, date])
  @@index([date, startTime])
  @@index([status])
}

// ==================== CUMULATIVE POINTS ====================

enum PointType {
  PRACTICE_ATTENDANCE     // + points for attending practice on time
  EXAM_COMPLETION         // + points for completing an exam
  NO_SHOW_PENALTY         // - points for not showing up after booking
  PROCTORING_WARNING      // - points for proctoring violations
  EXAM_CANCELLED_PENALTY  // - points for exam cancellation due to cheating
  MANUAL_ADJUSTMENT       // +/- points by admin
}

model PointTransaction {
  id            String    @id @default(uuid())
  
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  
  type          PointType
  points        Int        // Positive = earned, Negative = deducted
  reason        String
  
  // Optional references
  bookingId     String?
  examSessionId String?
  
  createdAt     DateTime  @default(now())
  
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// ==================== EXAM PROCTORING ====================

model ProctoringEvent {
  id           String      @id @default(uuid())
  
  sessionId    String
  session      ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  eventType    String      // "TAB_SWITCH", "WINDOW_BLUR", "COPY_PASTE", "FULLSCREEN_EXIT"
  warningLevel Int         @default(1)  // 1 = mild warning, 2 = severe, 3 = exam cancelled
  metadata     Json?       // Additional event data
  
  timestamp    DateTime    @default(now())
  
  @@index([sessionId])
  @@index([eventType])
}

// ==================== PRACTICE SESSION (Standalone) ====================

enum PracticeSessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model PracticeSession {
  id          String                @id @default(uuid())
  
  // Who
  userId      String
  user        User                  @relation(fields: [userId], references: [id])
  
  // Configuration (what the student chose)
  duration    Int                   // Duration in minutes
  totalItems  Int                   // Total number of items
  difficulty  Difficulty?           // Optional difficulty filter
  
  // Classification filters used
  subjectId   String?
  topicId     String?
  categoryId  String?
  
  // Timing
  startedAt   DateTime              @default(now())
  finishedAt  DateTime?
  
  // Scoring
  score       Float?
  maxScore    Float?
  
  // Status
  status      PracticeSessionStatus @default(IN_PROGRESS)
  
  // Relations
  items       PracticeSessionItem[]
  
  createdAt   DateTime              @default(now())
  
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// PracticeSessionItem - a question or problem in a practice session
model PracticeSessionItem {
  id          String          @id @default(uuid())
  
  sessionId   String
  session     PracticeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  // Either a question or a problem
  questionId  String?
  question    Question?       @relation(fields: [questionId], references: [id])
  problemId   String?
  problem     Problem?        @relation(fields: [problemId], references: [id])
  
  order       Int             @default(0)
  points      Float           @default(1.0)
  
  // Answer
  answers     PracticeSessionAnswer[]
  
  createdAt   DateTime        @default(now())
  
  @@index([sessionId])
}

// PracticeSessionAnswer - student's answer in a practice session
model PracticeSessionAnswer {
  id                String              @id @default(uuid())
  
  itemId            String
  item              PracticeSessionItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  // For MC questions
  selectedChoiceIds String[]
  
  // For short-answer questions
  textAnswer        String?             @db.Text
  
  // For coding problems
  sourceCode        String?             @db.Text
  language          String?
  languageVersion   String?
  submissionId      String?
  
  // Grading
  isCorrect         Boolean?
  score             Float?
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@unique([itemId])
  @@index([itemId])
}
