generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?  // User's full name
  password  String
  studentCode String?  @unique
  role      Role     @default(STUDENT)
  refreshToken  String?
  isEmailVerified Boolean @default(false)
  emailVerificationToken String?
  emailVerificationExpiry DateTime?
  resetPasswordCode String?
  resetPasswordExpiry DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  createdProblems Problem[] @relation("ProblemCreator")
  createdQuestions Question[] @relation("QuestionCreator")
  submissions     Submission[]
  createdExams    Exam[]        @relation("ExamCreator")
  examSessions    ExamSession[]
  
  // Indexes for common queries
  @@index([email])
  @@index([studentCode])
  @@index([role])
  @@index([isEmailVerified])
}

enum Role {
  STUDENT
  LECTURER
  ADMIN
}

// Problem difficulty levels (like LeetCode)
enum Difficulty {
  EASY
  MEDIUM
  HARD
}

// Problem model for coding challenges
model Problem {
  id          String     @id @default(uuid())
  title       String
  slug        String     @unique
  description String     @db.Text
  difficulty  Difficulty @default(MEDIUM)
  
  // Code templates for different languages
  starterCode Json?      // { "javascript": "function solve() {}", "python": "def solve():", ... }
  
  // Constraints and hints
  constraints String?    @db.Text
  hints       String[]   // Array of hints
  
  // Problem metadata
  timeLimit   Int        @default(1000)  // in milliseconds
  memoryLimit Int        @default(256)   // in MB

  // Function signature metadata for driver code generation
  functionName String   @default("solution")
  inputTypes   String[] @default([])
  outputType   String   @default("void")
  argNames     String[] @default([])
  
  // Stats
  totalSubmissions Int   @default(0)
  acceptedSubmissions Int @default(0)
  
  // Status
  isPublished Boolean    @default(false)
  
  // Classification (optional - links to question bank subjects/topics)
  subjectId   String?
  subject     Subject?   @relation(fields: [subjectId], references: [id])
  topicId     String?
  topic       Topic?     @relation(fields: [topicId], references: [id])
  
  // Relations
  creatorId   String
  creator     User       @relation("ProblemCreator", fields: [creatorId], references: [id])
  testCases   TestCase[]
  submissions Submission[]
  examItems   ExamItem[]  @relation("ProblemExamItems")
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  @@index([difficulty])
  @@index([isPublished])
  @@index([creatorId])
  @@index([subjectId])
  @@index([topicId])
}

// TestCase model with hidden test cases support
model TestCase {
  id          String   @id @default(uuid())
  
  // Test case data
  input       String   @db.Text
  expectedOutput String @db.Text
  
  // Explanation shown to users (only for visible test cases)
  explanation String?  @db.Text
  
  // Hidden test case flag (like LeetCode)
  isHidden    Boolean  @default(false)
  
  // Sample test case (shown in problem description)
  isSample    Boolean  @default(false)
  
  // Order of test case
  order       Int      @default(0)
  
  // Relations
  problemId   String
  problem     Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([problemId])
  @@index([isHidden])
  @@index([isSample])
}

// Submission status enum
enum SubmissionStatus {
  PENDING
  ACCEPTED
  WRONG_ANSWER
  COMPILE_ERROR
  RUNTIME_ERROR
  TIME_LIMIT_EXCEEDED
  MEMORY_LIMIT_EXCEEDED
}

// Submission model for storing user code submissions
model Submission {
  id              String           @id @default(uuid())
  
  // Code submitted
  language        String
  languageVersion String?
  sourceCode      String           @db.Text
  
  // Execution results
  status          SubmissionStatus @default(PENDING)
  totalTestCases  Int              @default(0)
  passedTestCases Int              @default(0)
  failedTestCases Int              @default(0)
  
  // Timing information
  executionTime   Int?             // Total execution time in ms
  networkTime     Int?             // Network latency in ms
  totalTime       Int?             // Total time (execution + network) in ms
  
  // Error information
  compileOutput   String?          @db.Text
  errorMessage    String?          @db.Text
  
  // Detailed results for each test case (JSON array)
  testCaseResults Json?            // Array of test case results
  
  // Relations
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId       String
  problem         Problem          @relation(fields: [problemId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime         @default(now())
  
  @@index([userId])
  @@index([problemId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, problemId])
}

// ==================== QUESTION BANK ====================

// Question type enum
enum QuestionType {
  SINGLE_CHOICE    // Single correct answer (ABCD)
  MULTIPLE_CHOICE  // Multiple correct answers
  SHORT_ANSWER     // Free-text short answer
}

// Subject model for question classification
model Subject {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?   @db.Text
  
  // Relations
  topics      Topic[]
  questions   Question[]
  problems    Problem[]
  exams       Exam[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Topic model (belongs to a Subject)
model Topic {
  id          String    @id @default(uuid())
  name        String
  
  // Relations
  subjectId   String
  subject     Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  questions   Question[]
  problems    Problem[]
  exams       Exam[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@unique([subjectId, name])
  @@index([subjectId])
}

// Question model for multiple-choice question bank
model Question {
  id            String       @id @default(uuid())
  
  // Question content
  content       String       @db.Text
  questionType  QuestionType @default(SINGLE_CHOICE)
  difficulty    Difficulty   @default(MEDIUM)
  
  // For SHORT_ANSWER questions
  correctAnswer String?      @db.Text
  
  // Explanation of the answer
  explanation   String?      @db.Text
  
  // Status
  isPublished   Boolean      @default(false)
  
  // Classification
  subjectId     String
  subject       Subject      @relation(fields: [subjectId], references: [id])
  topicId       String?
  topic         Topic?       @relation(fields: [topicId], references: [id])
  
  // Creator
  creatorId     String
  creator       User         @relation("QuestionCreator", fields: [creatorId], references: [id])
  
  // Relations
  choices       QuestionChoice[]
  examItems     ExamItem[]   @relation("QuestionExamItems")
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  
  @@index([questionType])
  @@index([difficulty])
  @@index([isPublished])
  @@index([subjectId])
  @@index([topicId])
  @@index([creatorId])
}

// QuestionChoice model for answer options
model QuestionChoice {
  id          String   @id @default(uuid())
  
  // Choice content
  content     String   @db.Text
  isCorrect   Boolean  @default(false)
  order       Int      @default(0)
  
  // Relations
  questionId  String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([questionId])
}

// ==================== EXAM SYSTEM ====================

// Exam section types
enum ExamSection {
  QUESTION  // Multiple-choice / short-answer from question bank
  PROBLEM   // Coding problems (LeetCode-style)
}

// Exam session status
enum ExamSessionStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

// Exam model - the exam template created by a lecturer
model Exam {
  id          String      @id @default(uuid())
  title       String
  description String?     @db.Text
  
  // Configuration
  questionCount Int       @default(0)   // Number of MC/short-answer questions
  problemCount  Int       @default(0)   // Number of coding problems
  duration      Int       @default(60)  // Duration in minutes
  
  // Filtering options used during generation
  difficulty  Difficulty?
  includeProblemsRelatedToQuestions Boolean @default(false)
  
  // Shuffle settings
  shuffleQuestions Boolean @default(true)   // Shuffle question order per student
  shuffleChoices  Boolean @default(true)   // Shuffle answer choices per student
  
  // Classification
  subjectId   String?
  subject     Subject?   @relation(fields: [subjectId], references: [id])
  topicId     String?
  topic       Topic?     @relation(fields: [topicId], references: [id])
  
  // Status
  isPublished Boolean    @default(false)
  
  // Creator
  creatorId   String
  creator     User       @relation("ExamCreator", fields: [creatorId], references: [id])
  
  // Relations
  items       ExamItem[]
  sessions    ExamSession[]
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  @@index([creatorId])
  @@index([subjectId])
  @@index([topicId])
  @@index([isPublished])
}

// ExamItem - a concrete item (question or problem) in an exam
model ExamItem {
  id        String      @id @default(uuid())
  
  // Which exam this belongs to
  examId    String
  exam      Exam        @relation(fields: [examId], references: [id], onDelete: Cascade)
  
  // Either a question or a problem (exactly one should be set)
  questionId String?
  question   Question?   @relation("QuestionExamItems", fields: [questionId], references: [id])
  problemId  String?
  problem    Problem?    @relation("ProblemExamItems", fields: [problemId], references: [id])
  
  // Section type
  section   ExamSection
  
  // Canonical (unshuffled) order
  order     Int         @default(0)
  
  // Points for this item
  points    Float       @default(1.0)
  
  // Relations
  sessionAnswers ExamSessionAnswer[]
  
  createdAt DateTime    @default(now())
  
  @@unique([examId, questionId])
  @@unique([examId, problemId])
  @@index([examId])
  @@index([section])
}

// ExamSession - one student's attempt at an exam
model ExamSession {
  id        String            @id @default(uuid())
  
  // Which exam
  examId    String
  exam      Exam              @relation(fields: [examId], references: [id], onDelete: Cascade)
  
  // Which student
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Deterministic shuffle seed
  seed      Int
  
  // Timing
  startedAt  DateTime         @default(now())
  finishedAt DateTime?
  
  // Scoring
  score      Float?
  maxScore   Float?
  
  // Status
  status    ExamSessionStatus @default(IN_PROGRESS)
  
  // Relations
  answers   ExamSessionAnswer[]
  
  createdAt DateTime          @default(now())
  
  @@unique([examId, userId])
  @@index([examId])
  @@index([userId])
  @@index([status])
}

// ExamSessionAnswer - each answer in a session
model ExamSessionAnswer {
  id          String      @id @default(uuid())
  
  // Which session
  sessionId   String
  session     ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  // Which exam item
  examItemId  String
  examItem    ExamItem    @relation(fields: [examItemId], references: [id], onDelete: Cascade)
  
  // For MC questions - selected choice IDs
  selectedChoiceIds String[]
  
  // For short-answer questions
  textAnswer  String?     @db.Text
  
  // For coding problems - reference to submission
  submissionId String?
  
  // For coding problems - store source code for deferred execution on submit
  sourceCode      String?   @db.Text
  language        String?
  languageVersion String?
  
  // Grading
  isCorrect   Boolean?
  score       Float?
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  @@unique([sessionId, examItemId])
  @@index([sessionId])
  @@index([examItemId])
}
