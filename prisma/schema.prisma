generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)
  refreshToken  String?
  createdAt DateTime @default(now())
}

enum Role {
  STUDENT
  LECTURER
  ADMIN
}
