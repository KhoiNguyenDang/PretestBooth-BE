generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String             @id @default(uuid())
  email                   String             @unique
  name                    String?
  password                String
  studentCode             String?            @unique
  role                    Role               @default(STUDENT)
  refreshToken            String?
  isEmailVerified         Boolean            @default(false)
  emailVerificationToken  String?
  emailVerificationExpiry DateTime?
  resetPasswordCode       String?
  resetPasswordExpiry     DateTime?
  isLocked                Boolean            @default(false)
  lockedAt                DateTime?
  lockedReason            String?
  dateOfBirth             DateTime?          @db.Date
  totalPoints             Int                @default(0)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  className               String?
  bookings                Booking[]
  boothStatusLogs         BoothStatusLog[]
  createdExams            Exam[]             @relation("ExamCreator")
  examSessions            ExamSession[]
  pointTransactions       PointTransaction[]
  practiceSessions        PracticeSession[]
  createdProblems         Problem[]          @relation("ProblemCreator")
  createdQuestions        Question[]         @relation("QuestionCreator")
  submissions             Submission[]

  @@index([email])
  @@index([studentCode])
  @@index([role])
  @@index([isEmailVerified])
  @@index([isLocked])
}

model Problem {
  id                  String                @id @default(uuid())
  title               String
  slug                String                @unique
  description         String
  difficulty          Difficulty            @default(MEDIUM)
  starterCode         Json?
  constraints         String?
  hints               String[]
  timeLimit           Int                   @default(1000)
  memoryLimit         Int                   @default(256)
  functionName        String                @default("solution")
  inputTypes          String[]              @default([])
  outputType          String                @default("void")
  argNames            String[]              @default([])
  totalSubmissions    Int                   @default(0)
  acceptedSubmissions Int                   @default(0)
  isPublished         Boolean               @default(false)
  subjectId           String?
  topicId             String?
  categoryId          String?
  creatorId           String
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  examItems           ExamItem[]            @relation("ProblemExamItems")
  practiceItems       PracticeSessionItem[]
  category            Category?             @relation(fields: [categoryId], references: [id])
  creator             User                  @relation("ProblemCreator", fields: [creatorId], references: [id])
  subject             Subject?              @relation(fields: [subjectId], references: [id])
  topic               Topic?                @relation(fields: [topicId], references: [id])
  submissions         Submission[]
  testCases           TestCase[]

  @@index([difficulty])
  @@index([isPublished])
  @@index([creatorId])
  @@index([subjectId])
  @@index([topicId])
  @@index([categoryId])
}

model TestCase {
  id             String   @id @default(uuid())
  input          String
  expectedOutput String
  explanation    String?
  isHidden       Boolean  @default(false)
  isSample       Boolean  @default(false)
  order          Int      @default(0)
  problemId      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  problem        Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId])
  @@index([isHidden])
  @@index([isSample])
}

model Submission {
  id              String           @id @default(uuid())
  language        String
  languageVersion String?
  sourceCode      String
  status          SubmissionStatus @default(PENDING)
  totalTestCases  Int              @default(0)
  passedTestCases Int              @default(0)
  failedTestCases Int              @default(0)
  executionTime   Int?
  networkTime     Int?
  totalTime       Int?
  compileOutput   String?
  errorMessage    String?
  testCaseResults Json?
  userId          String
  problemId       String
  createdAt       DateTime         @default(now())
  problem         Problem          @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([problemId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, problemId])
}

model Subject {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  exams       Exam[]
  problems    Problem[]
  questions   Question[]
  topics      Topic[]
}

model Topic {
  id        String     @id @default(uuid())
  name      String
  subjectId String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  exams     Exam[]
  problems  Problem[]
  questions Question[]
  subject   Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([subjectId, name])
  @@index([subjectId])
}

model Question {
  id             String                @id @default(uuid())
  content        String
  questionType   QuestionType          @default(SINGLE_CHOICE)
  difficulty     Difficulty            @default(MEDIUM)
  correctAnswer  String?
  explanation    String?
  isPublished    Boolean               @default(false)
  lastReviewedAt DateTime?
  reviewNotes    String?
  qualityScore   Int?
  usageCount     Int                   @default(0)
  estimatedTime  Int?
  subjectId      String
  topicId        String?
  categoryId     String?
  creatorId      String
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  examItems      ExamItem[]            @relation("QuestionExamItems")
  practiceItems  PracticeSessionItem[]
  category       Category?             @relation(fields: [categoryId], references: [id])
  creator        User                  @relation("QuestionCreator", fields: [creatorId], references: [id])
  subject        Subject               @relation(fields: [subjectId], references: [id])
  topic          Topic?                @relation(fields: [topicId], references: [id])
  choices        QuestionChoice[]

  @@index([questionType])
  @@index([difficulty])
  @@index([isPublished])
  @@index([subjectId])
  @@index([topicId])
  @@index([categoryId])
  @@index([creatorId])
}

model QuestionChoice {
  id         String   @id @default(uuid())
  content    String
  isCorrect  Boolean  @default(false)
  order      Int      @default(0)
  questionId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model Exam {
  id                                String         @id @default(uuid())
  title                             String
  description                       String?
  // Exam type: determines who can access (practice bookers vs exam bookers)
  type                              BookingType    @default(EXAM)
  questionCount                     Int            @default(0)
  problemCount                      Int            @default(0)
  duration                          Int            @default(60)
  difficulty                        Difficulty?
  includeProblemsRelatedToQuestions Boolean        @default(false)
  shuffleQuestions                  Boolean        @default(true)
  shuffleChoices                    Boolean        @default(true)
  subjectId                         String?
  topicId                           String?
  isPublished                       Boolean        @default(false)
  creatorId                         String
  createdAt                         DateTime       @default(now())
  updatedAt                         DateTime       @updatedAt
  visibility                        ExamVisibility @default(PRIVATE)
  publishAt                         DateTime?
  publishedAt                       DateTime?
  creator                           User           @relation("ExamCreator", fields: [creatorId], references: [id])
  subject                           Subject?       @relation(fields: [subjectId], references: [id])
  topic                             Topic?         @relation(fields: [topicId], references: [id])
  items                             ExamItem[]
  sessions                          ExamSession[]

  @@index([creatorId])
  @@index([subjectId])
  @@index([topicId])
  @@index([isPublished])
  @@index([visibility])
  @@index([publishAt])
}

model ExamItem {
  id             String              @id @default(uuid())
  examId         String
  questionId     String?
  problemId      String?
  section        ExamSection
  order          Int                 @default(0)
  points         Float               @default(1.0)
  createdAt      DateTime            @default(now())
  exam           Exam                @relation(fields: [examId], references: [id], onDelete: Cascade)
  problem        Problem?            @relation("ProblemExamItems", fields: [problemId], references: [id])
  question       Question?           @relation("QuestionExamItems", fields: [questionId], references: [id])
  sessionAnswers ExamSessionAnswer[]

  @@unique([examId, questionId])
  @@unique([examId, problemId])
  @@index([examId])
  @@index([section])
}

model ExamSession {
  id              String              @id @default(uuid())
  examId          String
  userId          String
  bookingId       String?
  seed            Int
  startedAt       DateTime            @default(now())
  finishedAt      DateTime?
  score           Float?
  maxScore        Float?
  status          ExamSessionStatus   @default(IN_PROGRESS)
  createdAt       DateTime            @default(now())
  expiresAt       DateTime            @default(now())
  exam            Exam                @relation(fields: [examId], references: [id], onDelete: Cascade)
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking         Booking?            @relation("ExamSessionBooking", fields: [bookingId], references: [id], onDelete: SetNull)
  answers         ExamSessionAnswer[]
  proctoringEvents ProctoringEvent[]

  @@unique([examId, userId])
  @@index([examId])
  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@index([bookingId])
}

model ExamSessionAnswer {
  id                String      @id @default(uuid())
  sessionId         String
  examItemId        String
  selectedChoiceIds String[]
  textAnswer        String?
  submissionId      String?
  sourceCode        String?
  language          String?
  languageVersion   String?
  isCorrect         Boolean?
  score             Float?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  examItem          ExamItem    @relation(fields: [examItemId], references: [id], onDelete: Cascade)
  session           ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, examItemId])
  @@index([sessionId])
  @@index([examItemId])
}

model Category {
  id          String     @id @default(uuid())
  name        String
  description String?
  level       Int        @default(0)
  parentId    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  problems    Problem[]
  questions   Question[]

  @@unique([parentId, name])
  @@index([parentId])
  @@index([level])
}

model Booth {
  id                     String           @id @default(uuid())
  name                   String           @unique
  description            String?
  status                 BoothStatus      @default(ACTIVE)
  location               String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  activationOtpAttempts  Int              @default(0)
  activationOtpExpiresAt DateTime?
  activationOtpHash      String?
  activationOtpUsedAt    DateTime?
  code                   String?          @unique
  sessionActivatedAt     DateTime?
  sessionTokenHash       String?
  bookings               Booking[]
  statusLogs             BoothStatusLog[]

  @@index([status])
}

model BoothStatusLog {
  id              String      @id @default(uuid())
  boothId         String
  fromStatus      BoothStatus
  toStatus        BoothStatus
  note            String
  changedByUserId String?
  changedAt       DateTime    @default(now())
  booth           Booth       @relation(fields: [boothId], references: [id], onDelete: Cascade)
  changedByUser   User?       @relation(fields: [changedByUserId], references: [id])

  @@index([boothId, changedAt])
  @@index([changedByUserId])
}

model BookingDurationOption {
  id              String      @id @default(uuid())
  type            BookingType
  durationMinutes Int
  isActive        Boolean     @default(true)
  displayOrder    Int?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([type, durationMinutes])
  @@index([type, isActive])
}

model Booking {
  id                String        @id @default(uuid())
  userId            String
  boothId           String
  type              BookingType
  date              DateTime      @db.Date
  startTime         DateTime
  endTime           DateTime
  durationMinutes   Int
  bufferMinutes     Int           @default(15)
  status            BookingStatus @default(PENDING)
  checkedInAt       DateTime?
  checkedOutAt      DateTime?
  
  // Relations - exam/practice sessions that reference this booking
  examSessions      ExamSession[]      @relation("ExamSessionBooking")
  practiceSessions  PracticeSession[]  @relation("PracticeSessionBooking")
  
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  
  booth   Booth @relation(fields: [boothId], references: [id])
  user    User  @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([boothId, date])
  @@index([date, startTime])
  @@index([status])
  @@index([boothId, startTime, endTime])
}

model PointTransaction {
  id            String    @id @default(uuid())
  userId        String
  type          PointType
  points        Int
  reason        String
  bookingId     String?
  examSessionId String?
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model ProctoringEvent {
  id           String      @id @default(uuid())
  
  // Either examSessionId or practiceSessionId should be set
  examSessionId    String?
  examSession      ExamSession? @relation(fields: [examSessionId], references: [id], onDelete: Cascade)
  
  practiceSessionId String?
  practiceSession   PracticeSession? @relation(fields: [practiceSessionId], references: [id], onDelete: Cascade)
  
  eventType    String      // "TAB_SWITCH", "WINDOW_BLUR", "COPY_PASTE", "FULLSCREEN_EXIT"
  warningLevel Int         @default(1)  // 1 = mild warning, 2 = severe, 3 = exam cancelled
  metadata     Json?       // Additional event data
  
  timestamp    DateTime    @default(now())
  
  @@index([examSessionId])
  @@index([practiceSessionId])
  @@index([eventType])
}

model PracticeSession {
  id         String                @id @default(uuid())
  userId     String
  bookingId  String?
  duration   Int
  totalItems Int
  difficulty Difficulty?
  subjectId  String?
  topicId    String?
  categoryId String?
  startedAt  DateTime              @default(now())
  finishedAt DateTime?
  score      Float?
  maxScore   Float?
  status     PracticeSessionStatus @default(IN_PROGRESS)
  createdAt  DateTime              @default(now())
  user       User                  @relation(fields: [userId], references: [id])
  booking    Booking?              @relation("PracticeSessionBooking", fields: [bookingId], references: [id], onDelete: SetNull)
  items      PracticeSessionItem[]
  proctoringEvents ProctoringEvent[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([bookingId])
}

model PracticeSessionItem {
  id         String                 @id @default(uuid())
  sessionId  String
  questionId String?
  problemId  String?
  order      Int                    @default(0)
  points     Float                  @default(1.0)
  createdAt  DateTime               @default(now())
  answers    PracticeSessionAnswer?
  problem    Problem?               @relation(fields: [problemId], references: [id])
  question   Question?              @relation(fields: [questionId], references: [id])
  session    PracticeSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model PracticeSessionAnswer {
  id                String              @id @default(uuid())
  itemId            String              @unique
  selectedChoiceIds String[]
  textAnswer        String?
  sourceCode        String?
  language          String?
  languageVersion   String?
  submissionId      String?
  isCorrect         Boolean?
  score             Float?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  item              PracticeSessionItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

enum Role {
  STUDENT
  LECTURER
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum SubmissionStatus {
  PENDING
  ACCEPTED
  WRONG_ANSWER
  COMPILE_ERROR
  RUNTIME_ERROR
  TIME_LIMIT_EXCEEDED
  MEMORY_LIMIT_EXCEEDED
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  SHORT_ANSWER
}

enum ExamSection {
  QUESTION
  PROBLEM
}

enum ExamVisibility {
  PRIVATE
  PUBLIC
}

enum ExamSessionStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

enum BoothStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

enum BookingType {
  PRACTICE
  EXAM
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PointType {
  PRACTICE_ATTENDANCE
  EXAM_COMPLETION
  NO_SHOW_PENALTY
  PROCTORING_WARNING
  EXAM_CANCELLED_PENALTY
  MANUAL_ADJUSTMENT
}

enum PracticeSessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}
